# === Database ===
DB__USER=postgres
DB__PASSWORD=your_password
DB__HOST=postgres
DB__PORT=5432
DB__NAME=aggregation
DB__POOL_SIZE=50
DB__MAX_OVERFLOW=10

# === Redis ===
REDIS__HOST=redis
REDIS__PORT=6378
REDIS__PASSWORD=
REDIS__DB=0

# === JWT (shared secret with user_service) ===
JWT__SECRET_KEY=your_secret_key_here

# === Arbitrage scanner ===
ARBITRAGE__PRICE_THRESHOLD=0.97   # max combined YES+NO entry cost
ARBITRAGE__MIN_SIZE=25            # min contract size in orderbook
ARBITRAGE__SCAN_INTERVAL=2        # seconds between scans
ARBITRAGE__CACHE_TTL=60           # Redis TTL for cached results (seconds)

# === Pair polling (ML similarity) ===
PAIR_POLLING__SIMILARITY_THRESHOLD=0.7
PAIR_POLLING__MAX_DISTANCE=0.5
PAIR_POLLING__POLL_INTERVAL=30

# === Sentry (optional) ===
SENTRY__DSN=
SENTRY__ENVIRONMENT=production

LOG_LEVEL=INFO
CORS_ORIGINS=["*"]