# === Database (same instance as aggregation_service) ===
DB__USER=postgres
DB__PASSWORD=your_password
DB__HOST=postgres
DB__PORT=5432
DB__NAME=aggregation

# === Embedding service (external Docker network: embedding_default) ===
EMBEDDING__URL=http://embedding-service:8080/embed
EMBEDDING__BATCH_SIZE=200
EMBEDDING__MAX_CONCURRENCY=8

# === Polymarket ===
POLYMARKET__PROXY_URL=http://your-proxy:port
POLYMARKET__POLL_INTERVAL=60
POLYMARKET__VOLUME_FILTER=500

# === Kalshi ===
KALSHI__PROXY_URL=http://your-proxy:port
KALSHI__POLL_INTERVAL=60
KALSHI__VOLUME_FILTER=500

# === PredictFun ===
PREDICT_FUN__API_KEY=your_predictfun_api_key
PREDICT_FUN__PROXY_URL=http://your-proxy:port
PREDICT_FUN__POLL_INTERVAL=60

# === Sentry (optional) ===
SENTRY_DSN=
ENV=production
LOG_LEVEL=INFO