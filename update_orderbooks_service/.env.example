# === Database (same instance as aggregation_service) ===
DB__USER=postgres
DB__PASSWORD=your_password
DB__HOST=postgres
DB__PORT=5432
DB__NAME=aggregation
DB__POOL_SIZE=1000

# === Kalshi WebSocket (RSA auth) ===
KALSHI__ACCESS_KEY=your_kalshi_access_key
KALSHI__PRIVATE_KEY_PATH=keys/kalshi_private_key.pem   # relative to service root
KALSHI__VOLUME_FILTER=10000

# === Polymarket WebSocket ===
POLYMARKET__PROXY_URL=http://your-proxy:port
POLYMARKET__VOLUME_FILTER=10000

# === PredictFun WebSocket ===
PREDICT_FUN__API_KEY=your_predictfun_api_key

# === Celery (Redis broker) ===
CELERY_BROKER_URL=redis://redis:6378/0
CELERY_RESULT_BACKEND=redis://redis:6378/0

# === Sentry (optional) ===
SENTRY_DSN=
ENV=production
LOG_LEVEL=INFO